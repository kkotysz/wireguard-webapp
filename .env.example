# App
APP_TITLE=WireGuard Status
WG_IFACE=wg0
# Leave empty to auto-use /etc/wireguard/<WG_IFACE>.conf
WG_CONF=
HANDSHAKE_FRESH_SECONDS=180
AUTO_REFRESH_SECONDS=10

# Flask/Gunicorn bind (for host-network deployment)
LISTEN_HOST=127.0.0.1
LISTEN_PORT=8000

# Gunicorn
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_LOGLEVEL=info

# Nginx
NGINX_LISTEN_PORT=8080
APP_UPSTREAM_HOST=127.0.0.1
APP_UPSTREAM_PORT=8000

# Host path mounted into the app container as /etc/wireguard
WG_CONFIG_DIR=/etc/wireguard
